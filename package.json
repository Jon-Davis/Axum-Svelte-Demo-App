{
  "name": "svelte-rust-test",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:types": "typeshare ./src --lang=typescript --config-file=typeshare.toml --output-file=src/lib/api/generated.ts",
    "dev": "npm run gen:types && vite dev",
    "build": "npm run gen:types && vite build",
    "preview": "vite preview",
    "check": "npm run gen:types && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  }
}
