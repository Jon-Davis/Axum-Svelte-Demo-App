{
  "openapi": "3.1.0",
  "info": {
    "title": "svelte-rust-test API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/admin/api_keys": {
      "get": {
        "tags": [
          "admin"
        ],
        "summary": "List all API keys (admin only).",
        "operationId": "getAdminApiKeys",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ApiKey"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "admin"
        ],
        "summary": "Create a new API key (admin only).",
        "operationId": "postAdminApiKeys",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/api_keys/{id}": {
      "delete": {
        "tags": [
          "admin"
        ],
        "summary": "Delete an API key by ID (admin only).",
        "operationId": "deleteAdminApiKeysById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        }
      }
    },
    "/api/hello": {
      "get": {
        "tags": [
          "hello"
        ],
        "summary": "Return a greeting, optionally personalised with the `name` query parameter.",
        "operationId": "getHello",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "Name to echo back in the greeting.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HelloResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/me": {
      "get": {
        "tags": [
          "me"
        ],
        "summary": "Return the authenticated caller's profile (email, username, role).",
        "operationId": "getMe",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserInfo"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiKey": {
        "type": "object",
        "description": "A key as shown in the admin panel (never includes the secret).",
        "required": [
          "id",
          "name",
          "role",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "expires_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "last_used_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "CreateRequest": {
        "type": "object",
        "required": [
          "name",
          "role"
        ],
        "properties": {
          "expires_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "CreateResponse": {
        "type": "object",
        "required": [
          "id",
          "name",
          "token"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "token": {
            "type": "string"
          }
        }
      },
      "HelloResponse": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "UserInfo": {
        "type": "object",
        "required": [
          "role"
        ],
        "properties": {
          "email": {
            "type": [
              "string",
              "null"
            ]
          },
          "role": {
            "type": "string"
          },
          "username": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
